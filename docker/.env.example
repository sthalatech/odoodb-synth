# docker/.env.example -- copy to docker/.env and edit as needed.
# Used by docker/docker-compose.scratch.yml.

# Scratch Postgres (postgres-anon service) credentials and host port.
# The scratch DB is where masking runs -- never point this at a real Odoo DB.
POSTGRES_USER=odoo_synth
POSTGRES_PASSWORD=odoo_synth
POSTGRES_DB=scratch
POSTGRES_PORT=5433

# Odoo service config.
ODOO_DB=odoo
ODOO_PORT=8069

# Connection string the CLI/tests use to reach the scratch Postgres.
# Override if you change the user/password/db above.
SCRATCH_DB_URL=postgresql://odoo_synth:odoo_synth@localhost:5433/scratch
